# =============================================================================
# AI Document Intelligence Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_SIZE_MB=50

# -----------------------------------------------------------------------------
# SQLite Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/platform.db

# -----------------------------------------------------------------------------
# ChromaDB
# -----------------------------------------------------------------------------
CHROMA_DB_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=documents

# -----------------------------------------------------------------------------
# Ollama
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT_SECONDS=600

# =============================================================================
# LLM Generation Parameters
# =============================================================================
# These parameters are optimized for deterministic SDS metadata extraction.

# Maximum output tokens.
# Metadata extraction only needs four short lines.
OLLAMA_NUM_PREDICT=96

# Context window supplied to the model.
OLLAMA_NUM_CTX=4096

# Deterministic output.
OLLAMA_TEMPERATURE=0

# Sampling configuration.
OLLAMA_TOP_K=20
OLLAMA_TOP_P=0.90

# Reduce repetitive generations.
OLLAMA_REPEAT_PENALTY=1.10

# Hardware settings.
# -1 = Ollama automatically determines GPU usage.
OLLAMA_NUM_GPU=-1

# CPU threads.
# 0 = Ollama automatically determines thread count.
OLLAMA_NUM_THREAD=0

# -----------------------------------------------------------------------------
# RAG Pipeline
# -----------------------------------------------------------------------------
CHUNK_SIZE=600
CHUNK_OVERLAP=100
RETRIEVAL_K=8
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
DEBUG_RAG=false
LOG_STAGES=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs